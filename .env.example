# Immoral Finance MCP Server - Environment Variables
# Copy this file to .env.local and fill in your values

# REQUIRED: Base URL of the Immoral Finance API (no trailing slash)
FINANCE_API_BASE_URL=

# REQUIRED: API key for the Finance API (format: ig_live_<key>)
FINANCE_API_KEY=

# OPTIONAL: defaults shown
NODE_ENV=development
REQUEST_TIMEOUT_MS=15000
LOG_LEVEL=info
